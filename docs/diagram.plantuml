' 2026-03-02 — sync diagram with actual source file decomposition
'   HTTP layer split into discrete files:
'     src/http/response_api.c      — alloc/free/set_* API
'     src/http/response_helpers.c  — http_send_*, http_render_template
'     src/http/response_file.c     — static file serving
'     src/http/response_io.c       — write_all, writev_all
'     src/http/response_pool.c     — sharded response pool
'     src/http/response_file_cache.c — sharded static file cache
'     src/http/utils_subprocess.c  — safe_popen_read_argv (split from utils.c)
'   Router url_registry split:
'     src/router/url_registry.c          — register_route, view_routes[]
'     src/router/url_registry_init.c     — init_routes entry point
'     src/router/url_registry_lookup.c   — route_match, route_path_known
'     src/router/url_registry_reverse.c  — route_reverse
'   Core conf split:
'     src/core/conf.c             — parser (conf_load, conf_apply_kv)
'     src/core/conf_defaults.c    — conf_defaults, conf_apply_cli, conf_dump
'     src/core/conf_validation.c  — conf_validate
'   Heartbeat split (already three files, now shown separately):
'     src/core/heartbeat.c          — public API + thread loop
'     src/core/heartbeat_schedule.c — due-task collection, wait logic
'     src/core/heartbeat_dispatch.c — batch reset/push/run
'   src/core/log.c added as explicit component (was implicit)
'   Metrics sub-components added:
'     src/modules/metrics/metrics_collectors.c
'     src/modules/metrics/metrics_process.c
'     src/modules/metrics/metrics_snapshot.c
'   Man sub-components added:
'     src/modules/man/man_query.c
'     src/modules/man/man_index.c
'     src/modules/man/man_render.c
'   2026-02-25 — sync with codebase after decomposition sprint (previous)
'     app_main.c split into net layer files
'     platform/openbsd/security.c extracted
'     Module decomposition scaffolds (Phase 3 stubs) added
