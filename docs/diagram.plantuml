@startuml
skinparam handwritten false
skinparam monochrome false
skinparam shadowing false
left to right direction

skinparam package {
  BorderColor #2d3436
}

skinparam component {
  BackgroundColor #F7FBFF
  BorderColor #2D3436
  FontColor #1F2933
}

' =========================
' AREA 1: PROJECT FUNCTIONS
' =========================
package "<&layers*1> Project functions" #EAF4FF {

  ' --- Bootstrap ---
  component "src/app_main.c\n(parse_args, main, handle_signal:\nbootstrap-only orchestration)" as Main #A8D8FF

  ' --- Net layer ---
  component "src/net/server.c\n(miniweb_server_run/stop,\nhandle_accept, sweep_idle)" as Server #90C8F0
  component "src/net/connection_pool.c\n(miniweb_connection_pool_init,\nminiweb_connection_alloc/free,\nminiweb_connection_is_stale)" as ConnPool #A0D0F8
  component "src/net/worker.c\n(miniweb_worker_thread,\nparse_request_line, route dispatch,\ntry_rearm_keepalive)" as Worker #B0D8FF
  component "src/net/work_queue.c\n(miniweb_work_queue_init/push/pop,\nbroadcast_shutdown)" as WQueue #B8DCFF

  ' --- HTTP layer (decomposed) ---
  component "src/http/response_api.c\n(http_response_alloc/free,\nhttp_response_set_*)" as HTTPApi #9ED9FF
  component "src/http/response_helpers.c\n(http_send_*, http_render_template)" as HTTPHelpers #9ED9FF
  component "src/http/response_file.c\n(http_send_file, static file serving)" as HTTPFile #9ED9FF
  component "src/http/response_io.c\n(write_all, writev_all)" as HTTPIo #9ED9FF
  component "src/http/response_pool.c\n(sharded response pool:\n16 shards × 1024 slots + heap fallback)" as HTTPPool #9ED9FF
  component "src/http/response_file_cache.c\n(sharded static file cache:\n16 shards × 32 slots, FNV hash,\n256 KiB/obj, 2-hit admission,\n8 inserts/sec budget, 120 s TTL)" as HTTPFileCache #9ED9FF
  component "src/http/utils.c\n(json_escape_string,\nsafe_popen_read)" as Utils #FFE6B2
  component "src/http/utils_subprocess.c\n(safe_popen_read_argv)" as UtilsSubproc #FFE6B2

  ' --- Router layer ---
  component "src/router/url_registry.c\n(register_route, view_routes[])" as URLReg #B8E0FF
  component "src/router/url_registry_init.c\n(url_registry_init)" as URLRegInit #C0E4FF
  component "src/router/url_registry_lookup.c\n(route_match, route_path_known,\nfind_view_route)" as URLRegLookup #C0E4FF
  component "src/router/url_registry_reverse.c\n(route_reverse)" as URLRegReverse #C0E4FF
  component "src/router/route_table.c\n(view_template_handler,\nstatic_handler, favicon_handler,\nhot-view cache)" as Routes #C4E8FF
  component "src/router/router.c\n(router_register,\nrouter_register_prefix)" as RouterC #D0EAFF
  component "src/router/module_attach.c\n(miniweb_module_attach_enabled)" as ModAttach #DCF0FF

  ' --- Feature modules: metrics ---
  component "src/modules/metrics/\nmetrics_module.c\n(metrics_module_attach_routes,\nmetrics_module_cleanup,\nroute handler)" as Metrics #D6EFFF
  component "src/modules/metrics/\nmetrics_collectors.c\n(collect CPU, memory, load,\nprocess list from sysctl)" as MetricsCollectors #DDF3FF
  component "src/modules/metrics/\nmetrics_process.c\n(per-process stats)" as MetricsProcess #DDF3FF
  component "src/modules/metrics/\nmetrics_snapshot.c\n(ring buffer + cached JSON snapshot;\nmetrics_heartbeat_cb)" as MetricsSnapshot #DDF3FF
  component "src/modules/metrics/\nmetrics_service.c\n[stub: metrics_service_build_payload]" as MetricsSvc #EAF6FF
  component "src/modules/metrics/\nmetrics_json.c\n[stub: metrics_json_build]" as MetricsJson #EAF6FF

  ' --- Feature modules: networking ---
  component "src/modules/networking/\nnetworking_module.c\n(networking_module_attach_routes,\nnetworking_module_cleanup,\nnetworking_*_handler)" as Net #CFE6FF
  component "src/modules/networking/\nnetworking_service.c\n[stub: networking_service_build_payload]" as NetSvc #E3F2FF
  component "src/modules/networking/\nnetworking_json.c\n[stub: networking_json_build]" as NetJson #E3F2FF

  ' --- Feature modules: man ---
  component "src/modules/man/\nman_module.c\n(man_module_attach_routes,\nman_module_cleanup,\nman_api_handler, man_render_handler)" as Man #E3F2FF
  component "src/modules/man/\nman_query.c\n(man page search / query)" as ManQuery #EAF6FF
  component "src/modules/man/\nman_index.c\n(man page index building)" as ManIndex #EAF6FF
  component "src/modules/man/\nman_render.c\n(mandoc invocation,\nfilesystem render cache)" as ManRender #EAF6FF
  component "src/modules/man/\nman_service.c\n[stub: man_service_search_json]" as ManSvc #EEF8FF
  component "src/modules/man/\nman_json.c\n[stub: man_json_sections]" as ManJson #EEF8FF

  ' --- Feature modules: packages ---
  component "src/modules/packages/\npackages_module.c\n(pkg_*_json, pkg_api_handler,\npackages_cache_cleanup)" as Pkg #D9F7FF
  component "src/modules/packages/\npackages_service.c\n[stub: packages_service_* — TBD]" as PkgSvc #E8FAFF
  component "src/modules/packages/\npackages_json.c\n[stub: packages_json_list]" as PkgJson #E8FAFF

  ' --- Render ---
  component "src/render/template_render.c\n(template_cache_init/cleanup,\ntemplate_render_with_data,\ntemplate_render)" as Template #FFF2B2

  ' --- Core ---
  component "src/core/conf.c\n(conf_load, conf_parse_file/line,\nconf_apply_kv)" as Conf #DFF7E2
  component "src/core/conf_defaults.c\n(conf_defaults, conf_apply_cli,\nconf_dump)" as ConfDefaults #DFF7E2
  component "src/core/conf_validation.c\n(conf_validate)" as ConfValidation #DFF7E2
  component "src/core/heartbeat.c\n(heartbeat_register/unregister/update,\nheartbeat_start/stop/shutdown,\nheartbeat_get_stats, heartbeat_thread)" as Heartbeat #D4F7DC
  component "src/core/heartbeat_schedule.c\n(hb_collect_due_tasks,\nhb_collect_all_active,\nhb_wait_for_next_tick, hb_mark_stopped)" as HeartbeatSched #D4F7DC
  component "src/core/heartbeat_dispatch.c\n(hb_batch_reset/push/run)" as HeartbeatDispatch #D4F7DC
  component "src/core/log.c\n(log_init/close,\nlog_info/error/debug,\nlog_set_verbose)" as Log #D4F7DC

  ' --- Platform ---
  component "src/platform/openbsd/security.c\n(miniweb_apply_openbsd_security:\nunveil + pledge)" as Security #D0F0D0

  ' --- Storage ---
  component "src/storage/\nsqlite_db.c / sqlite_schema.c\nsqlite_stmt.c\n(stubs: mw_db_*, mw_stmt_*, mw_tx_*)" as Storage #EEE0FF
}

' =============================
' AREA 2: STD C / POSIX LIBRARY
' =============================
package "<&book*1> Std C / POSIX library" #FFF7E6 {
  component "stdio.h\n(fopen/fclose/fread/fgets,\nprintf/fprintf/snprintf, sscanf)" as LibStdio #FFE1B3
  component "stdlib.h + string.h\n(malloc/calloc/free, getenv,\nstr* family, qsort)" as LibStd #FFE8C9
  component "pthread.h\n(pthread_*, cond/mutex ops)" as LibPthread #FFD8A8
  component "network libc\n(inet_pton/ntop, htons, getifaddrs,\nif_indextoname, gethostname)" as LibNet #FFEED8
  component "filesystem/dir libc\n(open/read/write, opendir/readdir,\nfstat, getmntinfo)" as LibFs #FFE4C4
  component "process/time libc\n(getopt, time/localtime_r,\ngetpwuid_r, difftime)" as LibProc #FFEBCF
}

' ==============
' AREA 3: KERNEL
' ==============
package "<&cloud*1> Kernel / system calls" #FFE9EC {
  component "kqueue/kevent" as Kevent #FFC6CF
  component "socket/accept/bind/listen" as Ksock #FFB8C6
  component "read/write/open/close/fcntl" as Kio #FFC9D4
  component "sysctl/swapctl/uname" as Ksys #FFD6DE
  component "signal/pledge/unveil" as Ksec #FFCCD6
}

' -------------------------
' Bootstrap -> layers
' -------------------------
Main --> Server        : miniweb_server_run/stop()\n(miniweb/net/server.h)
Main --> Conf          : conf_load()\n(miniweb/core/conf.h)
Main --> ConfDefaults  : conf_defaults(), conf_apply_cli()\n(miniweb/core/conf.h)
Main --> Log           : log_init(), log_set_verbose()\n(miniweb/core/log.h)
Main --> Template      : template_cache_init()\n(miniweb/render/template_engine.h)
Main --> URLRegInit    : init_routes()\n(miniweb/router/routes.h)
Main --> Security      : miniweb_apply_openbsd_security()\n(miniweb/platform/openbsd/security.h)

' -------------------------
' Conf internal
' -------------------------
Conf --> ConfValidation : conf_validate()
Conf --> ConfDefaults   : (shares miniweb_conf_t)

' -------------------------
' Net layer internal
' -------------------------
Server --> ConnPool  : miniweb_connection_pool_init(),\nminiweb_connection_alloc/free(),\nminiweb_connection_is_stale()
Server --> WQueue    : miniweb_work_queue_init(),\nminiweb_work_queue_push(),\nbroadcast_shutdown()
Server --> Worker    : pthread_create(miniweb_worker_thread)
Server --> HTTPHelpers : http_send_error() [503 on queue full]

Worker --> WQueue       : miniweb_work_queue_pop()
Worker --> ConnPool     : miniweb_connection_free()
Worker --> URLRegLookup : route_match(), route_path_known()
Worker --> HTTPHelpers  : http_send_error() [400/404/405]

' -------------------------
' Router layer
' -------------------------
URLRegInit   --> URLReg        : populates view_routes[]
URLRegInit   --> ModAttach     : miniweb_module_attach_enabled()
URLReg       --> URLRegLookup  : (shared view_routes[] table)
URLReg       --> URLRegReverse : (shared view_routes[] table)
ModAttach    --> Routes        : views_module_attach_routes()
ModAttach    --> Metrics       : metrics_module_attach_routes()
ModAttach    --> Net           : networking_module_attach_routes()
ModAttach    --> Man           : man_module_attach_routes()
ModAttach    --> Pkg           : packages_module_attach_routes()
ModAttach    --> RouterC       : router_register(),\nrouter_register_prefix()

Routes --> Template    : template_render_with_data()
Routes --> HTTPHelpers : http_send_*, http_response_*

' -------------------------
' HTTP layer internal
' -------------------------
HTTPHelpers --> HTTPApi      : http_response_alloc/free/set_*
HTTPHelpers --> HTTPIo       : write_all(), writev_all()
HTTPFile    --> HTTPFileCache : cache lookup/insert
HTTPFile    --> HTTPIo       : write_all()
HTTPPool    --> HTTPApi      : pooled allocation
HTTPHelpers --> HTTPPool     : pool alloc/free

' -------------------------
' Heartbeat internal
' -------------------------
Heartbeat --> HeartbeatSched    : hb_collect_due_tasks(),\nhb_collect_all_active(),\nhb_wait_for_next_tick()
Heartbeat --> HeartbeatDispatch : hb_batch_reset/push/run()

' -------------------------
' Module -> sub-components
' -------------------------
Metrics --> MetricsCollectors : collect system metrics
Metrics --> MetricsProcess    : per-process stats
Metrics --> MetricsSnapshot   : ring buffer, cached JSON,\nmetrics_heartbeat_cb

Metrics --> MetricsSvc        : metrics_service_build_payload() [stub]
Metrics --> MetricsJson       : metrics_json_build() [stub]
Net     --> NetSvc            : networking_service_build_payload() [stub]
Net     --> NetJson           : networking_json_build() [stub]
Man     --> ManQuery          : man page search
Man     --> ManIndex          : index building
Man     --> ManRender         : mandoc render + fs cache
Man     --> ManSvc            : man_service_search_json() [stub]
Man     --> ManJson           : man_json_sections() [stub]
Pkg     --> PkgSvc            : packages_service_* [stub — TBD]
Pkg     --> PkgJson           : packages_json_list() [stub]

' -------------------------
' Modules -> shared services
' -------------------------
Metrics --> HTTPHelpers : http_response_*, http_send_error()
Metrics --> Utils       : json_escape_string()
Metrics --> Heartbeat   : heartbeat_register("metrics.sample"),\nheartbeat_start()

Net --> HTTPHelpers : http_response_*, http_send_error(),\nhttp_render_template()
Net --> Heartbeat   : heartbeat_register("networking.sample"),\nheartbeat_start()

Man --> HTTPHelpers  : http_response_*, http_send_error()
Man --> UtilsSubproc : safe_popen_read_argv()
Man --> Routes       : static_handler() [cache hit path]

Pkg --> HTTPHelpers  : http_response_*, http_send_json(),\nhttp_send_error()
Pkg --> Utils        : json_escape_string()
Pkg --> UtilsSubproc : safe_popen_read_argv()

Template --> Template : read_template_file(), replace_single(),\nreplace_all(), template_cache_refresh_locked()

' -----------------------------------
' Project -> Std C / POSIX lib calls
' -----------------------------------
Conf --> LibStdio : fopen/fgets/fclose/fprintf/snprintf
Conf --> LibStd   : memset/strtol/strcasecmp/strcmp/strlen/strlcpy
Conf --> LibProc  : getenv

ConfDefaults --> LibStd   : memset/strlcpy
ConfDefaults --> LibStdio : fprintf

Main --> LibProc : getopt, signal, atoi
Main --> LibStd  : strlcpy

Server --> LibPthread : pthread_create/join
Server --> LibNet     : inet_pton, htons
Server --> LibProc    : time()
Server --> LibStd     : memset

Worker --> LibStd  : strchr/strstr/strcasestr/memcpy/strcmp
Worker --> LibProc : time(), recv()

ConnPool --> LibPthread : mutex ops
ConnPool --> LibProc    : time()
ConnPool --> LibStd     : memset/memcpy

WQueue --> LibPthread : mutex/cond ops
WQueue --> LibStd     : memset

HTTPApi --> LibStd : calloc/malloc/free/memcpy/strlen
HTTPHelpers --> LibStdio : snprintf
HTTPHelpers --> LibNet   : inet_ntop
HTTPIo --> LibFs : write/writev
HTTPFile --> LibFs : open/read/close/fstat
HTTPFileCache --> LibFs : fstat [mtime validation]
HTTPPool --> LibStd : calloc/malloc/free

Template --> LibStdio : fopen/fseek/ftell/fread/fclose/snprintf
Template --> LibStd   : malloc/free/memcpy/strlen/strstr/strdup

Heartbeat --> LibPthread : pthread_create/join/cond_timedwait
Heartbeat --> LibProc    : time()
HeartbeatSched --> LibProc : clock_gettime()

Log --> LibStdio : fprintf, fopen/fclose

Metrics --> LibProc    : time/localtime_r/strftime
Metrics --> LibNet     : getifaddrs/freeifaddrs/inet_ntop/gethostname
Metrics --> LibStd     : malloc/calloc/free/qsort/snprintf/str*
Metrics --> LibPthread : mutex ops
MetricsCollectors --> LibProc : sysctl wrappers
MetricsProcess --> LibProc    : sysctl/getpwuid_r

Net --> LibStdio   : fopen/fgets/fclose/snprintf
Net --> LibNet     : if_indextoname/inet_ntop/getifaddrs/freeifaddrs
Net --> LibStd     : malloc/free/memset/str*
Net --> LibPthread : mutex ops

Man --> LibStd : malloc/free/strdup/strlen/str*
Man --> LibFs  : opendir/readdir/closedir, mkdir_p, write_file_binary
ManRender --> LibProc : waitpid/pipe/fork (via popen)

Pkg --> LibStd : malloc/free/strtol/strtok_r/str*

Routes --> LibStd     : snprintf/strncmp/strstr/strlen/time
Routes --> LibPthread : mutex ops [hot-view cache]
URLReg --> LibStd : strcmp/strncmp
Utils --> LibStd : malloc/strdup/strlen/isalnum
UtilsSubproc --> LibProc : popen/pclose/fgets

' ----------------------
' System call tracking
' ----------------------
Server --> Kevent : kqueue(), kevent()
Server --> Ksock  : socket(), bind(), listen(), accept(), setsockopt()
Server --> Kio    : close(), fcntl()

Worker --> Kio    : recv(), close()
Worker --> Kevent : kevent() [EV_ENABLE / EV_DELETE]

Security --> Ksec : pledge(), unveil()
Main --> Ksec     : signal()

HTTPFile      --> Kio  : open(), read(), close()
HTTPIo        --> Kio  : write(), writev()
MetricsCollectors --> Ksys : sysctl(KERN_CPTIME, KERN_PROC_ALL,\nvm.uvmexp, vm.loadavg, kern.*)
MetricsProcess --> Ksys : sysctl(KERN_PROC_ALL)
Net --> Ksys : sysctl(NET_RT_DUMP)

' libc wrappers to kernel (conceptual)
LibPthread --> Kio   : futex/sched primitives (platform-dependent)
LibFs      --> Kio   : file descriptor syscalls
LibNet     --> Ksock : socket stack syscalls
LibProc    --> Ksys  : time/proc/sysctl wrappers

' ----------------------
' Notes
' ----------------------
note right of Main
  Bootstrap only (~120 LOC):
  parse_args → conf → log → template_cache
  → init_routes → security → server_run
  Hard caps (compile-time):
  MAX_CONNECTIONS=4096
  THREAD_POOL_SIZE=32
  REQUEST_BUFFER_SIZE=16384
  QUEUE_CAPACITY=4096
  MAX_KEEPALIVE_REQUESTS=64
end note

note right of Server
  Two-tier model:
  - Dispatcher: kqueue accept loop + idle sweep
  - Workers: N pthreads dequeue + dispatch
  EV_DISPATCH prevents multi-worker races.
  EMFILE guard: /dev/null spare fd trick.
end note

note right of HTTPFileCache
  Sharded static file cache:
  - 16 shards × 32 slots (FNV path hash)
  - 256 KiB/object max
  - 2-hit admission candidate table
  - token budget: 8 inserts/sec per shard
  - age eviction: 120 s
  - mtime validation on hit
end note

note right of HTTPPool
  Response pool:
  16 shards × 1024 slots
  + heap fallback on exhaustion
end note

note bottom of URLRegLookup
  Route resolution order:
  1) exact registered routes (linear scan)
  2) prefix routes (/man/, /api/man,
     /api/packages, /static/)
  Known path + wrong method → 405 + Allow
  Unknown path → 404
end note

note right of Net
  /api/networking fast path:
  heartbeat task (1 s) → ring buffer
  + pre-built cached JSON snapshot
  fallback: on-demand collect + serialize
  TCP/UDP connection enum: placeholder only
end note

note right of ManRender
  Filesystem render cache path:
  {static_dir}/man/{area}/{section}/{page}.{fmt}
  Cached formats: html / utf8 / md / ps / pdf
  Cache hit → served via static_handler()
end note

note right of Template
  templates_dir preloaded at startup by
  template_cache_init(); lazily refreshed
  every TEMPLATE_CACHE_TTL_SEC (60 s).
  Placeholders: {{title}}, {{page_content}},
  {{extra_head}}, {{extra_js}}
end note

note right of Heartbeat
  Up to HB_MAX_TASKS=32 named tasks.
  Tracks: runs, overruns, last_run, last_error.
  heartbeat_shutdown(drain=1) executes
  all tasks once before exit.
  Active tasks:
  - metrics.sample (1 s)
  - networking.sample (1 s)
end note

note right of Storage
  Phase 5 stubs — not yet implemented.
  All functions return -1.
  APIs: mw_db_open/close,
  mw_db_exec_schema, mw_db_migrate,
  mw_tx_begin/commit/rollback,
  mw_stmt_prepare/bind/step/finalize
end note

note bottom of MetricsSvc
  Decomposition scaffold — Phase 3.
  Function bodies to be migrated
  from metrics_module.c.
  Same applies to metrics_json.c,
  net/man/packages *_service.c
  and *_json.c counterparts.
end note

@enduml

