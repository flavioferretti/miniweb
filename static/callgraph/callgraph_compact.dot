digraph callgraph {
  // miniweb — compact call graph (depth 3, no stdlib)
  rankdir=TB;
  bgcolor="#1e1e2e";
  fontname="Monaco";
  nodesep=0.55;
  ranksep=0.8;
  splines=curved;

  node [shape=box, style="filled,rounded", fontname="Monaco",
        fontsize=9, fillcolor="#313244", color="#585b70",
        fontcolor="#cdd6f4", penwidth=1.2];
  edge [color="#585b70", arrowhead=normal, penwidth=1.0,
        fontname="Monaco", fontsize=7];

  "main" -> "parse_args";
  "parse_args" -> "usage";
  "parse_args" -> "conf_defaults";
  "parse_args" -> "conf_load";
  "parse_args" -> "conf_apply_cli";
  "main" -> "log_init";
  "main" -> "log_set_verbose";
  "main" -> "log_info";
  "log_info" -> "log_write";
  "main" -> "conf_dump";
  "main" -> "template_cache_init";
  "template_cache_init" -> "template_cache_reload_locked";
  "main" -> "log_error";
  "log_error" -> "log_write";
  "main" -> "init_routes";
  "init_routes" -> "url_registry_register";
  "init_routes" -> "url_registry_register_prefix";
  "init_routes" -> "views_module_attach_routes";
  "init_routes" -> "metrics_module_attach_routes";
  "init_routes" -> "networking_module_attach_routes";
  "init_routes" -> "man_module_attach_routes";
  "init_routes" -> "packages_module_attach_routes";
  "init_routes" -> "miniweb_module_attach_enabled";
  "main" -> "handle_signal";
  "handle_signal" -> "miniweb_server_stop";
  "main" -> "miniweb_apply_openbsd_security";
  "miniweb_apply_openbsd_security" -> "unveil";
  "miniweb_apply_openbsd_security" -> "pledge";
  "miniweb_apply_openbsd_security" -> "log_errno";
  "miniweb_apply_openbsd_security" -> "log_error";
  "miniweb_apply_openbsd_security" -> "log_debug";
  "main" -> "miniweb_server_run";
  "miniweb_server_run" -> "miniweb_work_queue_init";
  "miniweb_server_run" -> "miniweb_connection_pool_init";
  "miniweb_server_run" -> "set_nonblock";
  "miniweb_server_run" -> "kqueue";
  "miniweb_server_run" -> "kevent";
  "miniweb_server_run" -> "sweep_idle";
  "miniweb_server_run" -> "miniweb_work_queue_broadcast_shutdown";
  "main" -> "man_module_cleanup";
  "man_module_cleanup" -> "man_render_cache_cleanup";
  "main" -> "networking_module_cleanup";
  "networking_module_cleanup" -> "pthread_mutex_destroy";
  "main" -> "metrics_module_cleanup";
  "metrics_module_cleanup" -> "ring_free";
  "main" -> "packages_cache_cleanup";
  "packages_cache_cleanup" -> "log_debug";
  "packages_cache_cleanup" -> "pkg_ring_free";
  "main" -> "http_handler_globals_cleanup";
  "main" -> "template_cache_cleanup";
  "main" -> "log_close";

  // Entry-point node
  main [fillcolor="#89b4fa", color="#1e1e2e",
        fontcolor="#1e1e2e", penwidth=2, shape=doublecircle];
}
